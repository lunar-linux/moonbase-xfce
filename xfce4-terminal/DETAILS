          MODULE=xfce4-terminal
         VERSION=1.2.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=https://archive.xfce.org/src/apps/$MODULE/${VERSION::3}
      SOURCE_VFY=sha256:6874c7b975cc3dc3bd636d57ffec723de7458202defe65377593d3a7e0734b94
        WEB_SITE=http://www.xfce.org/projects/terminal
            TYPE=meson
         ENTERED=20040930
         UPDATED=20260330
           SHORT="vte-based gtk+-3 lightweight X-terminal"

cat << EOF
xfce4-terminal is a modern terminal emulator for the Unix/Linux desktop -
primarily for the Xfce desktop environment. We developed it because
we saw the need for a lightweight and easy-to-use terminal emulator
in the Xfce desktop environment, that doesn't require the user to
install the GNOME platform, but still provides a worthy alternative
to the GNOME terminal emulator.
EOF
